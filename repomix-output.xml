<file path="src/components/modal/LibraryModal.jsx">
import OutsideClickHandler from "../OutsideClickHandler";
import { Button, Typography, Box } from "@mui/material";
import CloseIcon from "@mui/icons-material/Close";
import CheckBoxIcon from "@mui/icons-material/CheckBox";
import TurnedInIcon from "@mui/icons-material/TurnedIn";
import FavoriteIcon from "@mui/icons-material/Favorite";
import DeleteIcon from "@mui/icons-material/Delete";
import PropTypes from "prop-types";
import "../../styles/Modal.css";
import { addBookStatus, removeBookStatus } from "../../services/userServices";

const LibraryModal = ({
  closeModal,
  bookId,
  userId,
  bookState,
  setBookState,
  redirectToLogIn,
}) => {
  const toggleState = async (stateKey) => {
    redirectToLogIn();
    if (!userId) return;

    try {
      if (bookState[stateKey]) {
        await removeBookStatus(userId, bookId, stateKey);
      } else {
        await addBookStatus(userId, bookId, stateKey);
      }

      // Update local state to reflect change immediately
      setBookState((prevState) => ({
        ...prevState,
        [stateKey]: !prevState[stateKey],
      }));
    } catch (error) {
      console.error(`Error toggling ${stateKey}:`, error);
    }
  };

  /**
   * buttonStyle ensures that the buttons have a consistent height and
   * look so the modal doesn't shift when text changes.
   */
  const buttonStyle = (isActive) => ({
    display: "flex",
    justifyContent: "space-between",
    alignItems: "center",
    padding: "0 20px",
    height: "56px", // Fixed height to prevent modal resizing
    borderRadius: "16px",
    textTransform: "none",
    backgroundColor: isActive
      ? "rgba(37, 209, 218, 0.08)"
      : "rgba(255, 255, 255, 0.03)",
    color: isActive ? "var(--accent-blue)" : "var(--text-secondary)",
    border: `1px solid ${isActive ? "var(--accent-blue)" : "var(--border-subtle)"}`,
    transition: "all 0.2s ease-in-out",
    "&:hover": {
      backgroundColor: isActive
        ? "rgba(37, 209, 218, 0.15)"
        : "rgba(255, 255, 255, 0.08)",
      borderColor: "var(--accent-blue)",
      color: "var(--text-primary)",
    },
    "&.Mui-disabled": {
      opacity: 0.4,
      borderColor: "transparent",
      color: "var(--text-secondary)",
    },
  });

  return (
    <div className="modal-overlay">
      <OutsideClickHandler onOutsideClick={closeModal}>
        {/* Wrapper div for styling (The CSS handles the slideDown animation) */}
        <div className="modal-content">
          <div className="modal-header">
            <Typography
              variant="h6"
              sx={{ fontWeight: 800, color: "var(--text-primary)" }}
            >
              Library Status
            </Typography>
            <button
              className="modal-close-btn"
              onClick={closeModal}
              aria-label="Close"
            >
              <CloseIcon />
            </button>
          </div>

          <div className="modal-body">
            {/* Have Read Toggle */}
            <Button
              variant="outlined"
              sx={buttonStyle(bookState.haveRead)}
              fullWidth
              onClick={() => toggleState("haveRead")}
              disabled={bookState.readLater}
            >
              <Typography variant="body2" sx={{ fontWeight: 600 }}>
                {bookState.haveRead ? 'In "Have Read"' : "Mark as Read"}
              </Typography>
              {bookState.haveRead ? (
                <DeleteIcon fontSize="small" />
              ) : (
                <CheckBoxIcon fontSize="small" />
              )}
            </Button>

            {/* Read Later Toggle */}
            <Button
              variant="outlined"
              sx={buttonStyle(bookState.readLater)}
              fullWidth
              onClick={() => toggleState("readLater")}
              disabled={bookState.haveRead}
            >
              <Typography variant="body2" sx={{ fontWeight: 600 }}>
                {bookState.readLater ? 'In "Read Later"' : "Want to Read"}
              </Typography>
              {bookState.readLater ? (
                <DeleteIcon fontSize="small" />
              ) : (
                <TurnedInIcon fontSize="small" />
              )}
            </Button>

            {/* Favorites Toggle */}
            <Button
              variant="outlined"
              sx={buttonStyle(bookState.favorites)}
              fullWidth
              onClick={() => toggleState("favorites")}
            >
              <Typography variant="body2" sx={{ fontWeight: 600 }}>
                {bookState.favorites ? 'In "Favorites"' : "Add to Favorites"}
              </Typography>
              {bookState.favorites ? (
                <DeleteIcon fontSize="small" />
              ) : (
                <FavoriteIcon fontSize="small" />
              )}
            </Button>
          </div>

          <Box sx={{ mt: "auto", pt: 2, textAlign: "center" }}>
            <Typography
              variant="caption"
              sx={{
                color: "var(--text-secondary)",
                fontStyle: "italic",
                opacity: 0.7,
              }}
            >
              Changes are saved to your cloud profile.
            </Typography>
          </Box>
        </div>
      </OutsideClickHandler>
    </div>
  );
};

LibraryModal.propTypes = {
  closeModal: PropTypes.func.isRequired,
  bookId: PropTypes.string.isRequired,
  userId: PropTypes.string,
  bookState: PropTypes.object.isRequired,
  setBookState: PropTypes.func.isRequired,
  redirectToLogIn: PropTypes.func.isRequired,
};

export default LibraryModal;
</file>

