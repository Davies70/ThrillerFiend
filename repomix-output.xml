          <div className="book-rating-container">
            <span className="rating-status">{ratingPrompt}</span>
            <Rating
              size="large"
              precision={0.5}
              onChange={handleRating}
              value={currentRating}
              disabled={!user}
              sx={{
                color: "var(--accent-blue)",
                "& .MuiRating-iconEmpty": { color: "var(--text-secondary)" },
              }}
            />
