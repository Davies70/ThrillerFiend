<file path="src/services/userServices.js">
import { db } from "../firebase/config";
import {
  doc,
  setDoc,
  serverTimestamp,
  updateDoc,
  getDoc,
  arrayRemove,
  arrayUnion,
} from "firebase/firestore";
import bookServices from "./bookServices";

// ==========================================
// USER CREATION & VERIFICATION
// ==========================================

export const createUser = async (id) => {
  try {
    const userRef = doc(db, "users", id);
    await setDoc(userRef, {
      id,
      haveRead: [],
      readLater: [],
      wantToRead: [],
      favorites: [],
      notes: {},
      ratings: {},
      following: [],
      created: serverTimestamp(),
    });
  } catch (error) {
    console.error("Error creating user:", error);
  }
};

export const getUser = async (id) => {
  try {
    const userRef = doc(db, "users", id);
    const userDoc = await getDoc(userRef);
    return userDoc.exists() ? userDoc.data() : null;
  } catch (error) {
    console.error("Error getting user:", error);
    return null;
  }
};

export const doesUserExist = async (id) => {
  try {
    const userRef = doc(db, "users", id);
    const userDoc = await getDoc(userRef);
    return userDoc.exists();
  } catch (error) {
    console.error("Error checking if user exists:", error);
    return false;
  }
};

// ==========================================
// PRIVATE NOTES
// ==========================================

export const writeNote = async (userId, bookId, noteText) => {
  try {
    const notesRef = doc(db, "users", userId, "notes", bookId);
    const notesDoc = await getDoc(notesRef);
    const existingNotes = notesDoc.data()?.bookNotes || [];

    const newNote = {
      noteText,
      created: new Date().getTime(),
    };

    await setDoc(notesRef, {
      bookNotes: [...existingNotes, newNote],
    });
  } catch (error) {
    console.error("Error adding note:", error);
  }
};

export const deleteNote = async (userId, bookId, noteId) => {
  try {
    const notesRef = doc(db, "users", userId, "notes", bookId);
    const notesDoc = await getDoc(notesRef);
    const existingNotes = notesDoc.data()?.bookNotes || [];

    const noteToDelete = existingNotes[noteId];

    if (noteToDelete) {
      await updateDoc(notesRef, {
        bookNotes: arrayRemove(noteToDelete),
      });
    }
  } catch (error) {
    console.error("Error deleting note:", error);
  }
};

export const updateNote = async (userId, bookId, noteId, updatedNoteText) => {
  try {
    const notesRef = doc(db, "users", userId, "notes", bookId);
    const notesDoc = await getDoc(notesRef);
    const existingNotes = notesDoc.data()?.bookNotes || [];

    if (existingNotes[noteId]) {
      existingNotes[noteId].noteText = updatedNoteText;
      await updateDoc(notesRef, {
        bookNotes: existingNotes,
      });
    }
  } catch (error) {
    console.error("Error updating note:", error);
  }
};

// ==========================================
// RATINGS
// ==========================================

export const writeRating = async (userId, bookId, rating) => {
  try {
    const userRef = doc(db, "users", userId);
    await updateDoc(userRef, {
      [`ratings.${bookId}`]: rating,
    });
  } catch (error) {
    console.error("Error adding rating:", error);
  }
};

export const getRating = async (userId, bookId) => {
  try {
    const userRef = doc(db, "users", userId);
    const userDoc = await getDoc(userRef);
    return userDoc.data()?.ratings?.[bookId] || null;
  } catch (error) {
    console.error("Error getting rating:", error);
    return null;
  }
};

// ==========================================
// BOOK COLLECTION STATUS (Have Read, Read Later, Favorites)
// ==========================================

export const getBookStatus = async (userId, bookId, status) => {
  try {
    const userRef = doc(db, "users", userId);
    const userDoc = await getDoc(userRef);

    if (!userDoc.exists()) return false;

    const data = userDoc.data();

    // If no specific status is requested, return an object of all statuses
    if (!status) {
      return {
        haveRead: data.haveRead?.includes(bookId) || false,
        readLater: data.readLater?.includes(bookId) || false,
        favorites: data.favorites?.includes(bookId) || false,
      };
    }

    // Otherwise, return boolean for specific status
    return data[status]?.includes(bookId) || false;
  } catch (error) {
    console.error("Error fetching book status:", error);
    return false;
  }
};

export const addBookStatus = async (userId, bookId, status) => {
  try {
    const userRef = doc(db, "users", userId);
    const userDoc = await getDoc(userRef);

    if (!userDoc.exists()) return;

    const data = userDoc.data();

    // Core update: add to the requested list
    await updateDoc(userRef, {
      [status]: arrayUnion(bookId),
    });

    // Special Logic: If marking as "haveRead", automatically remove from "readLater"
    if (status === "haveRead" && data.readLater?.includes(bookId)) {
      await updateDoc(userRef, {
        readLater: arrayRemove(bookId),
      });
    }
  } catch (error) {
    console.error(`Error adding ${status} status:`, error);
  }
};

export const removeBookStatus = async (userId, bookId, status) => {
  try {
    const userRef = doc(db, "users", userId);
    await updateDoc(userRef, {
      [status]: arrayRemove(bookId),
    });
  } catch (error) {
    console.error(`Error removing ${status} status:`, error);
  }
};

// ==========================================
// FETCHING POPULATED COLLECTIONS
// ==========================================

export const getReadLaterAndHaveReadCount = async (userId) => {
  try {
    const userRef = doc(db, "users", userId);
    const userDoc = await getDoc(userRef);

    if (!userDoc.exists()) return { haveReadCount: 0, readLaterCount: 0 };

    const data = userDoc.data();
    return {
      haveReadCount: data.haveRead?.length || 0,
      readLaterCount: data.readLater?.length || 0,
    };
  } catch (error) {
    console.error("Error fetching collection counts:", error);
    return { haveReadCount: 0, readLaterCount: 0 };
  }
};

/**
 * Replaces getReadLaters, getHaveReads, and getFavorites.
 * Dynamically fetches the user's list based on the status key.
 */
export const getBooksByStatus = async (userId, status) => {
  try {
    const userRef = doc(db, "users", userId);
    const userDoc = await getDoc(userRef);

    if (!userDoc.exists()) return [];

    const bookIds = userDoc.data()[status];

    if (!bookIds || bookIds.length === 0) return [];

    // Fetch full book details for all IDs in the list
    const books = await Promise.all(
      bookIds.map(async (bookId) => {
        try {
          return await bookServices.getBookByVolumeId(bookId);
        } catch (err) {
          console.error(`Failed to fetch details for book ID: ${bookId}`, err);
          return null;
        }
      }),
    );

    // Filter out any null values in case a book was deleted from the API
    return books.filter(Boolean);
  } catch (error) {
    console.error(`Error fetching ${status} list:`, error);
    return [];
  }
};
</file>

