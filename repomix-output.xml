<file path="src/pages/Collections.jsx">
import { useState, useEffect } from "react";
import { useQueries } from "@tanstack/react-query";
import { useAuth } from "../context/AuthProvider";
import { getBooksByStatus } from "../services/userServices";
import { Link, useNavigate } from "react-router-dom";

// MUI
import Tabs from "@mui/material/Tabs";
import Tab from "@mui/material/Tab";
import Box from "@mui/material/Box";
import LibraryBooksIcon from "@mui/icons-material/LibraryBooks";

// Components
import Shape from "../components/Shape";
import Loader from "../components/Loader";
import "../styles/pages/Collections.css";

const Collections = () => {
  // 1. Core Hooks
  const { user, loading: authLoading } = useAuth();
  const navigate = useNavigate();
  const [activeTab, setActiveTab] = useState("haveRead");

  // 2. Fetch all three collections in parallel on initial mount
  const [haveReadQuery, readLaterQuery, favoritesQuery] = useQueries({
    queries: [
      {
        queryKey: ["collection", user?.uid, "haveRead"],
        queryFn: () => getBooksByStatus(user?.uid, "haveRead"),
        enabled: !!user?.uid,
      },
      {
        queryKey: ["collection", user?.uid, "readLater"],
        queryFn: () => getBooksByStatus(user?.uid, "readLater"),
        enabled: !!user?.uid,
      },
      {
        queryKey: ["collection", user?.uid, "favorites"],
        queryFn: () => getBooksByStatus(user?.uid, "favorites"),
        enabled: !!user?.uid,
      },
    ],
  });

  // 3. Security Redirect
  useEffect(() => {
    if (!authLoading && !user) {
      navigate("/signin");
    }
  }, [user, authLoading, navigate]);

  const handleTabChange = (event, newValue) => {
    setActiveTab(newValue);
  };

  // 4. Loading & Error States
  const isQueriesLoading =
    haveReadQuery.isLoading ||
    readLaterQuery.isLoading ||
    favoritesQuery.isLoading;

  const isQueriesError =
    haveReadQuery.isError || readLaterQuery.isError || favoritesQuery.isError;

  if (authLoading || (!user && !authLoading)) return <Loader />;
  if (isQueriesLoading) return <Loader />;
  if (isQueriesError)
    return (
      <div
        style={{
          textAlign: "center",
          marginTop: "40px",
          color: "var(--text-primary)",
        }}
      >
        Error loading your collections. Please try again.
      </div>
    );

  // 5. Map the pre-loaded data to an object so we can instantly grab the active one
  const collectionsData = {
    haveRead: haveReadQuery.data || [],
    readLater: readLaterQuery.data || [],
    favorites: favoritesQuery.data || [],
  };

  const activeBooks = collectionsData[activeTab];

  return (
    <div className="collections-page">
      {/* Custom Premium Header */}
      <div className="collections-header">
        <h1>Your Library</h1>
        <p>
          Your curated collection of dark mysteries, twisted thrillers, and
          favorite reads.
        </p>
      </div>

      {/* Styled MUI Tabs */}
      <Box className="tabs-container">
        <Tabs
          value={activeTab}
          onChange={handleTabChange}
          variant="scrollable"
          scrollButtons="auto"
          allowScrollButtonsMobile
          sx={{
            minHeight: "48px",
            "& .MuiTabs-indicator": {
              backgroundColor: "var(--accent-blue)",
              height: "3px",
              borderRadius: "3px 3px 0 0",
            },
          }}
        >
          <Tab
            value="haveRead"
            label="Have Read"
            disableRipple
            sx={{
              textTransform: "none",
              fontSize: "1rem",
              fontWeight: 600,
              color: "var(--text-secondary)",
              "&.Mui-selected": { color: "var(--text-primary)" },
            }}
          />
          <Tab
            value="readLater"
            label="Read Later"
            disableRipple
            sx={{
              textTransform: "none",
              fontSize: "1rem",
              fontWeight: 600,
              color: "var(--text-secondary)",
              "&.Mui-selected": { color: "var(--text-primary)" },
            }}
          />
          <Tab
            value="favorites"
            label="Favorites"
            disableRipple
            sx={{
              textTransform: "none",
              fontSize: "1rem",
              fontWeight: 600,
              color: "var(--text-secondary)",
              "&.Mui-selected": { color: "var(--text-primary)" },
            }}
          />
        </Tabs>
      </Box>

      {/* Grid or Empty State */}
      {activeBooks.length > 0 ? (
        <div className="collections-grid" key={activeTab}>
          {activeBooks.map((book) => (
            <Shape shape="square" book={book} key={book.book_id || book.id} />
          ))}
        </div>
      ) : (
        <div className="empty-collection" key={`empty-${activeTab}`}>
          <LibraryBooksIcon
            sx={{ fontSize: 64, color: "var(--border-subtle)", mb: 2 }}
          />
          <h3>It's quiet here...</h3>
          <p>
            You haven't added any books to this collection yet. Head over to the{" "}
            <Link
              to="/"
              style={{ color: "var(--accent-blue)", textDecoration: "none" }}
            >
              Home
            </Link>{" "}
            page to discover your next thrill.
          </p>
        </div>
      )}
    </div>
  );
};

export default Collections;
</file>

